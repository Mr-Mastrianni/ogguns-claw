# Telegram Bot Token from @BotFather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Comma-separated list of allowed Telegram user IDs (numbers only)
# Get your ID from @userinfobot
ALLOWED_USER_IDS=123456789

# LLM Provider: "nvidia" or "openrouter"
LLM_PROVIDER=nvidia

# --- NVIDIA NIM (default) ---
# Get API key at: https://build.nvidia.com/settings/api-keys
NVIDIA_API_KEY=your_nvidia_api_key_here
NVIDIA_MODEL=minimaxai/minimax-m2.7
# Other NVIDIA models:
#   minimaxai/minimax-m2.5
#   nvidia/llama-3.3-nemotron-super-49b-v1.5
#   nvidia/nemotron-3-super-120b-a12b
#   deepseek-ai/deepseek-r1

# --- OpenRouter (alternative) ---
# Get API key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=minimax/minimax-m2.5:free
# Other free OpenRouter models:
#   openrouter/free
#   meta-llama/llama-3.3-70b-instruct:free
#   deepseek/deepseek-r1:free

# Optional: Max agent loop iterations (default: 10)
# MAX_AGENT_ITERATIONS=10

# Deployment mode: "webhook" for Railway/cloud, "polling" for local dev
# BOT_MODE=webhook

# Required for webhook mode (Railway sets this automatically, or set manually):
# WEBHOOK_URL=https://your-app.railway.app
# WEBHOOK_PATH=/webhook
# PORT=3000

# Turso Database (free cloud SQLite)
# Sign up at: https://turso.tech
# Create a database, then run: turso db tokens create gravity-claw --read-write
TURSO_DATABASE_URL=libsql://your-db.turso.io
TURSO_AUTH_TOKEN=your_turso_auth_token_here
