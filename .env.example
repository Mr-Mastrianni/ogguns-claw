# Telegram Bot Token from @BotFather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# OpenRouter API Key (free models, no credit card required)
# Get yours at: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Comma-separated list of allowed Telegram user IDs (numbers only)
# Get your ID from @userinfobot
ALLOWED_USER_IDS=123456789

# LLM Model (OpenRouter model ID)
# Default: minimax/minimax-m2.5:free
# Other free options: openrouter/free, meta-llama/llama-3.3-70b-instruct:free,
#   deepseek/deepseek-r1:free, nvidia/nemotron-3-super-120b-a12b:free
LLM_MODEL=minimax/minimax-m2.5:free

# Optional: Max agent loop iterations (default: 10)
# MAX_AGENT_ITERATIONS=10

# Deployment mode: "webhook" for Railway/cloud, "polling" for local dev
# BOT_MODE=webhook

# Required for webhook mode (Railway sets this automatically, or set manually):
# WEBHOOK_URL=https://your-app.railway.app
# WEBHOOK_PATH=/webhook
# PORT=3000

# Turso Database (free cloud SQLite)
# Sign up at: https://turso.tech
# Create a database, then run: turso db tokens create gravity-claw --read-write
TURSO_DATABASE_URL=libsql://your-db.turso.io
TURSO_AUTH_TOKEN=your_turso_auth_token_here
